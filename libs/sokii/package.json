{
  "name": "sokii",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./worker": {
      "types": "./src/worker/index.ts",
      "bun": "./src/worker/index.ts",
      "import": "./dist/worker/index.js",
      "require": "./dist/worker/index.cjs"
    }
  },
  "files": [
    "package.json",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun test --watch --coverage",
    "publish": "bun exec 'NODE_ENV=production bun run scripts/publish.ts'"
  }
}
